---
import type { Lang } from '../../data/i18n';
import { translations } from '../../data/i18n';
interface Props { lang: Lang }
const { lang } = Astro.props;
const gm = (translations[lang] as any).gemini;
---

<section id="top">
  <div class="hero-container">
    <div class="hero-content">
      <h1
        data-gm-reveal
        set:html={gm.heroTitle.split('\n').join('<br>')}
      />
      <p
        data-gm-reveal
        style="transition-delay: 0.15s"
      >
        {gm.heroSubtitle}
      </p>
      <div
        class="hero-ctas"
        data-gm-reveal
        style="transition-delay: 0.3s"
      >
        <a href="#works" class="btn-primary">
          {gm.ctaPrimary}
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <a href="#about" class="btn-ghost">
          {gm.ctaSecondary}
        </a>
      </div>
    </div>
  </div>

  <div class="scroll-indicator" data-gm-reveal style="transition-delay: 1.5s">
    <span class="scroll-hint">{gm.scrollHint}</span>
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  section#top {
    position: relative;
    height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-container {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  @media (max-width: 480px) {
    .hero-container {
      padding: 0 1rem;
    }
  }

  @media (min-width: 768px) {
    .hero-container {
      padding: 0 3rem;
    }
  }

  .hero-content {
    max-width: 56rem;
  }

  h1 {
    font-size: clamp(2.25rem, 7vw, 4.5rem);
    font-weight: 900;
    letter-spacing: -0.05em;
    line-height: 1.1;
    margin-bottom: 2rem;
    background: linear-gradient(to right, var(--gm-text-primary), var(--gm-text-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  p {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--gm-text-secondary);
    max-width: 42rem;
    font-weight: 300;
    letter-spacing: 0.025em;
    margin-bottom: 2.5rem;
    line-height: 1.625;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    background: white;
    color: black;
    font-weight: 600;
    border-radius: 9999px;
    transition: background 0.3s;
    text-decoration: none;
  }

  .btn-primary:hover {
    background: var(--gm-text-secondary);
  }

  .btn-primary:focus-visible {
    outline: 2px solid var(--gm-accent-blue);
    outline-offset: 2px;
  }

  .btn-ghost {
    padding: 1rem 2rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: white;
    font-weight: 600;
    border-radius: 9999px;
    transition: background 0.3s;
    text-decoration: none;
  }

  .btn-ghost:hover {
    background: rgba(255, 255, 255, 0.05);
  }

  .btn-ghost:focus-visible {
    outline: 2px solid rgba(71, 97, 140, 0.6);
    outline-offset: 2px;
  }

  .scroll-indicator {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .scroll-hint {
    color: var(--gm-text-muted);
    font-size: 0.875rem;
  }

  .scroll-line {
    width: 1px;
    height: 3rem;
    background: linear-gradient(to bottom, var(--gm-text-muted), transparent);
  }
</style>
