---
import type { Lang } from '../../data/i18n';
import MolecularNetwork from './MolecularNetwork.tsx';

interface Props { lang: Lang }
const { lang } = Astro.props;

const copy: Record<Lang, { label: string; title: string; lede: string; caption: string }> = {
  en: {
    label: 'Research network',
    title: 'A graph of the work, not a list.',
    lede: 'Sixteen publications, four countries, three primary institutions. The network is dense by design — collaboration is the substrate, not the byproduct.',
    caption: 'Hover any node to surface its institution and one-hop neighbourhood.',
  },
  es: {
    label: 'Red de investigación',
    title: 'Un grafo del trabajo, no una lista.',
    lede: 'Dieciséis publicaciones, cuatro países, tres instituciones principales. La red es densa por diseño — la colaboración es el sustrato, no el subproducto.',
    caption: 'Pasa el cursor sobre cualquier nodo para mostrar su institución y vecindario de primer grado.',
  },
  ca: {
    label: 'Xarxa de recerca',
    title: 'Un graf del treball, no una llista.',
    lede: 'Setze publicacions, quatre països, tres institucions principals. La xarxa és densa per disseny — la col·laboració és el substrat, no el subproducte.',
    caption: 'Passa el cursor sobre qualsevol node per mostrar la seva institució i veïnatge de primer grau.',
  },
};

const t = copy[lang];
---

<section id="network" class="network-section">
  <div class="inner">
    <div data-gm-reveal class="section-header">
      <h2 class="section-label">{t.label}</h2>
      <div class="divider"></div>
    </div>

    <div class="content">
      <div data-gm-slide="left" class="lede">
        <h3 class="title">{t.title}</h3>
        <p class="body">{t.lede}</p>
        <p class="caption">{t.caption}</p>
      </div>

      <div data-gm-slide="right" class="viz">
        <MolecularNetwork client:visible />
      </div>
    </div>
  </div>
</section>

<style>
  .network-section {
    position: relative;
    z-index: 1;
    padding: 8rem 1.5rem;
    background:
      radial-gradient(ellipse at 20% 0%, rgba(196,149,106,0.04) 0%, transparent 55%),
      linear-gradient(180deg, #080B11 0%, #0B1018 50%, #080B11 100%);
  }

  @media (min-width: 768px) {
    .network-section { padding: 9rem 3rem; }
  }

  .inner {
    max-width: 80rem;
    margin: 0 auto;
  }

  .section-header { margin-bottom: 3.5rem; }
  .section-label {
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gm-accent-blue);
    margin-bottom: 1rem;
  }
  .divider {
    height: 1px;
    width: 100%;
    background: var(--border-light);
  }

  .content {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .content {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.7fr);
      gap: 4rem;
    }
  }

  .title {
    font-size: clamp(1.75rem, 3.6vw, 2.6rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    font-weight: 600;
    color: var(--gm-text-primary);
    margin-bottom: 1.25rem;
    text-wrap: balance;
  }

  .body {
    font-size: clamp(0.95rem, 1.4vw, 1.1rem);
    color: var(--gm-text-secondary);
    line-height: 1.7;
    max-width: 36rem;
    margin-bottom: 1.5rem;
  }

  .caption {
    font-family: 'JetBrains Mono', 'SF Mono', ui-monospace, monospace;
    font-size: 0.75rem;
    letter-spacing: 0.02em;
    color: var(--gm-text-muted);
    text-transform: lowercase;
    border-left: 2px solid rgba(196, 149, 106, 0.6);
    padding-left: 0.85rem;
  }

  .viz {
    position: relative;
    height: clamp(28rem, 62vh, 40rem);
    border-radius: 1.25rem;
    background: radial-gradient(ellipse at 50% 40%, rgba(20, 26, 36, 0.7) 0%, rgba(8, 11, 17, 0.9) 100%);
    border: 1px solid rgba(196, 149, 106, 0.18);
    overflow: hidden;
    contain: layout paint;
  }

  @media (prefers-reduced-motion: reduce) {
    .network-section { background: rgba(8,11,17,0.4); }
  }
</style>
