---
import Layout from '../../layouts/Layout.astro';
import ImmersiveBackground from '../../components/gemini/ImmersiveBackground.astro';
import NavGemini from '../../components/gemini/NavGemini.astro';
import HeroDiffusion from '../../components/HeroDiffusion.astro';
import WorksGemini from '../../components/gemini/WorksGemini.astro';
import AboutGemini from '../../components/gemini/AboutGemini.astro';
import WritingGemini from '../../components/gemini/WritingGemini.astro';
import ContactGemini from '../../components/gemini/ContactGemini.astro';
import { translations } from '../../data/i18n';
const gm = (translations.es as any).gemini;
const heroTitleHtml = gm.heroTitle.split('\n').join('<br>');
---

<Layout
  title="Ramon Roca Pinilla - Ingeniero Biomédico"
  description="Ingeniero biomédico especializado en proteínas antimicrobianas, vectores AAV y cuerpos de inclusión funcionales."
  lang="es"
  theme="gemini"
>
  <ImmersiveBackground />
  <NavGemini lang="es" />
  <HeroDiffusion>
    <Fragment slot="title" set:html={heroTitleHtml} />
    <Fragment slot="subtitle">{gm.heroSubtitle}</Fragment>
    <Fragment slot="ctas">
      <a href="#works" class="btn-primary">{gm.ctaPrimary}</a>
      <a href="#about" class="btn-ghost">{gm.ctaSecondary}</a>
    </Fragment>
  </HeroDiffusion>
  <WorksGemini lang="es" />
  <AboutGemini lang="es" />
  <WritingGemini lang="es" />
  <ContactGemini lang="es" />
</Layout>
