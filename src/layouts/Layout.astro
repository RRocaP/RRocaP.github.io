      [data-theme='gemini'] [data-gm-reveal]{opacity:0;transform:translateY(30px);transition:opacity 0.8s cubic-bezier(0.25,1,0.5,1),transform 0.8s cubic-bezier(0.25,1,0.5,1)}
      [data-theme='gemini'] [data-gm-reveal].is-visible{opacity:1;transform:translateY(0)}
      [data-theme='gemini'] [data-gm-slide="left"]{opacity:0;transform:translateX(-30px);transition:opacity 0.8s ease,transform 0.8s ease}
      [data-theme='gemini'] [data-gm-slide="right"]{opacity:0;transform:translateX(30px);transition:opacity 0.8s ease,transform 0.8s ease}
      [data-theme='gemini'] [data-gm-slide].is-visible{opacity:1;transform:translateX(0)}
